{
  "name": "afghan-typing-master",
  "private": true,
  "version": "1.0.0",
  "description": "Master your typing skills in multiple languages including English, Pashto, and Dari",
  "author": {
    "name": "Shahid Ullah Safi",
    "email": "contact@shahiddev.com",
    "url": "https://shahiddev.com"
  },
  "license": "MIT",
  "homepage": "https://github.com/ShahidKhanDev/afghan-typing-master-source",
  "keywords": [
    "typing",
    "keyboard",
    "practice",
    "pashto",
    "dari",
    "afghan",
    "education",
    "electron"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:win64": "tsc && vite build && electron-builder --win --x64",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "build:win:nsis:x64": "npm run build && electron-builder --win nsis --x64",
    "build:win:nsis:ia32": "npm run build && electron-builder --win nsis --ia32",
    "build:win:portable:x64": "npm run build && electron-builder --win portable --x64",
    "build:win:portable:ia32": "npm run build && electron-builder --win portable --ia32",
    "build:win:zip:x64": "npm run build && electron-builder --win zip --x64",
    "build:win:zip:ia32": "npm run build && electron-builder --win zip --ia32",
    "build:win:all:x64": "npm run build && electron-builder --win nsis portable zip --x64",
    "build:win:all:ia32": "npm run build && electron-builder --win nsis portable zip --ia32",
    "build:win:all": "npm run build && electron-builder --win nsis portable zip --x64 --ia32 --publish always",
    "clean": "rimraf dist dist-electron release",
    "clean:build": "npm run clean && npm run build",
    "postinstall": "electron-builder install-app-deps",
    "commit": "cz",
    "release": "semantic-release"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "dependencies": {
    "@heroui/spinner": "^2.2.24",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@semantic-release/exec": "^7.1.0",
    "@tailwindcss/vite": "^4.1.17",
    "@types/react-router-dom": "^5.3.3",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "conventional-changelog-conventionalcommits": "^9.3.0",
    "electron-updater": "^6.8.3",
    "embla-carousel-react": "^8.6.0",
    "i18next": "^25.6.3",
    "i18next-browser-languagedetector": "^8.2.0",
    "lucide-react": "^0.554.0",
    "motion": "^12.26.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^16.3.4",
    "react-router-dom": "^6.30.2",
    "react-use-measure": "^2.1.7",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.17",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^24.10.1",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@vitejs/plugin-react": "^4.2.1",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "rimraf": "^5.0.5",
    "semantic-release": "^25.0.3",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.2.2",
    "vite": "^5.1.6",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "main": "dist-electron/main.js"
}
